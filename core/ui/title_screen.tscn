[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://core/ui/title_screen.gd" id="1_title"]

[node name="TitleScreen" type="Control"]
script = ExtResource("1_title")
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Margin" type="MarginContainer" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 24
theme_override_constants/margin_right = 24
theme_override_constants/margin_bottom = 24

[node name="VBox" type="VBoxContainer" parent="Margin"]

[node name="Title" type="Label" parent="Margin/VBox"]
text = "Choose your campaign"
theme_override_font_sizes/font_size = 32

[node name="Subtitle" type="Label" parent="Margin/VBox"]
text = "Four FE-foundation tactics roguelites, one engine."
modulate = Color(1, 1, 1, 0.6)

[node name="Spacer" type="Control" parent="Margin/VBox"]
custom_minimum_size = Vector2(0, 16)

[node name="PackList" type="VBoxContainer" parent="Margin/VBox"]
size_flags_vertical = 3
