[gd_resource type="Resource" script_class="EventDef" load_steps=4 format=3]

[ext_resource type="Script" path="res://core/data/event_def.gd" id="1_def"]
[ext_resource type="Script" path="res://core/data/event_choice.gd" id="2_choice"]

[sub_resource type="Resource" id="ChoiceTouch"]
script = ExtResource("2_choice")
label = "Lay your palm on the stone"
outcome_text = "Old grief flows up your arm and recedes. When you take your hand away, your grip is sure on the road again."
gold_delta = 0
meta_currency_delta = 3
party_hp_delta = 1

[sub_resource type="Resource" id="ChoiceSkip"]
script = ExtResource("2_choice")
label = "Give the stone a wide berth"
outcome_text = "Your column passes the stone in silence. None of you look back. The stone neither follows nor cares."
gold_delta = 0
meta_currency_delta = 0
party_hp_delta = 0

[resource]
script = ExtResource("1_def")
id = &"abandoned_oath_stone"
display_name = "An Abandoned Oath-Stone"
body = "A small Pact-stone leans alone in a hollow off the road. Whoever was bonded here is long gone. The stone still holds the imprint of two palms."
choices = [SubResource("ChoiceTouch"), SubResource("ChoiceSkip")]
act_min = 0
act_max = 99
weight = 9
