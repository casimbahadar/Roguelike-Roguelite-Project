[sub_resource type="Resource" id="ChoiceBarter"]
script = ExtResource("2_choice")
label = "Barter the camp's offered cache"
outcome_text = "They take your coin without speaking and slide a small box across the firelight. Inside, two charms in good repair and one in better."
