[ext_resource type="Script" path="res://core/data/event_choice.gd" id="2_choice"]

[sub_resource type="Resource" id="ChoiceAid"]
script = ExtResource("2_choice")
label = "Aid the courier across"
outcome_text = "You lend a vessel to bear the courier's wax-sealed bundle the last mile. The seal is from a house your lord has not heard from in a year."
gold_delta = 4
meta_currency_delta = 4
party_hp_delta = 0

[sub_resource type="Resource" id="ChoiceRebuff"]
script = ExtResource("2_choice")
label = "Send the courier on alone"
outcome_text = "The courier bows low and disappears into the mist with the bundle still strapped to her back. A debt unmade."
gold_delta = 0
meta_currency_delta = 0
party_hp_delta = 0

[resource]
script = ExtResource("1_def")
id = &"spirit_courier"
display_name = "A Spirit Courier"
body = "A pale sprite-vessel in courier's gear flags your column down. Her bond-charm is half-severed and she cannot cross the next league of road alone."
choices = [SubResource("ChoiceAid"), SubResource("ChoiceRebuff")]
act_min = 0
act_max = 99
weight = 9
