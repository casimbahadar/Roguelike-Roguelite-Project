[sub_resource type="Resource" id="ChoiceMourn"]
script = ExtResource("2_choice")
label = "Sit with the lord"
outcome_text = "An hour at the cairn. The lord rises with new resolve and a quieter step. The campaign's mood is heavier and steadier in the same breath."
gold_delta = 0
meta_currency_delta = 5
party_hp_delta = 0

[sub_resource type="Resource" id="ChoiceTakeRelic"]
script = ExtResource("2_choice")
label = "Take the offering bowl"
outcome_text = "A few coins, a thumb's-width of cracked obsidian, an oath-cord. Useful. The lord does not look at your captain for the rest of the road."
gold_delta = 5
meta_currency_delta = -3
party_hp_delta = 0

[sub_resource type="Resource" id="ChoicePass"]
script = ExtResource("2_choice")
label = "Walk past"
outcome_text = "The lord does not lift their head. The road takes you on."
gold_delta = 0
meta_currency_delta = 0
party_hp_delta = 0

[resource]
script = ExtResource("1_def")
id = &"severed_companion"
display_name = "A Mourner at the Cairn"
body = "A lord kneels at a low stone cairn beside the road. A vessel-cord lies across the stones — the kind worn by a Pact that has ended. The lord does not look up."
choices = [SubResource("ChoiceMourn"), SubResource("ChoiceTakeRelic"), SubResource("ChoicePass")]
act_min = 0
act_max = 99
weight = 10
