[ext_resource type="Script" path="res://core/data/event_choice.gd" id="2_choice"]

[sub_resource type="Resource" id="ChoiceShare"]
script = ExtResource("2_choice")
label = "Share the shard's warmth"
outcome_text = "The bearer presses a sliver of crystal into your captain's palm. It sings, very faintly, all the way to the next ridgeline."
gold_delta = 0
meta_currency_delta = 5
party_hp_delta = 0

[sub_resource type="Resource" id="ChoiceTake"]
script = ExtResource("2_choice")
label = "Take the shard"
outcome_text = "The bearer does not resist. The shard is yours, the road is yours, and something at the edge of hearing has gone quiet that should not have been."
gold_delta = 6
meta_currency_delta = -3
party_hp_delta = 0

[sub_resource type="Resource" id="ChoicePass"]
script = ExtResource("2_choice")
label = "Pass without speaking"
outcome_text = "The bearer bows once and walks on. So do you."
gold_delta = 0
meta_currency_delta = 0
party_hp_delta = 0

[resource]
script = ExtResource("1_def")
id = &"crystal_bearer"
display_name = "The Crystal-Bearer"
body = "A traveler walks the road wrapped in road-stained linen, a fragment of the shattered Crystal cradled in both hands. The shard pulses, slow and warm. The bearer's eyes do not."
choices = [SubResource("ChoiceShare"), SubResource("ChoiceTake"), SubResource("ChoicePass")]
act_min = 0
act_max = 99
weight = 10
