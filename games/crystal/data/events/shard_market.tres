[resource]
script = ExtResource("1_def")
id = &"shard_market"
display_name = "The Shard Market"
body = "A boy hawks 'sealed surprise pouches' from a folding table at the road junction. Half the coin in the pouch is real, he swears. The rest is shard-glass."
