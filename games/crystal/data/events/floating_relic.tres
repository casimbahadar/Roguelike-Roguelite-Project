party_hp_delta = 0

[resource]
script = ExtResource("1_def")
id = &"floating_relic"
display_name = "A Floating Relic"
body = "Wedged into a stone spire above the road sits a small sealed box, weathered to the colour of bone. No-one's bothered to climb up for it in years."
