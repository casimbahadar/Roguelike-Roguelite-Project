[sub_resource type="Resource" id="ChoiceLeave"]
script = ExtResource("2_choice")
label = "Leave the relic where it sits"
outcome_text = "Your scout swears she sees the relic still up there a week later, when the column rounds back along the same ridge."
gold_delta = 0
