[ext_resource type="Resource" path="res://games/crystal/data/encounters/roadside_ambush.tres" id="2_ambush"]
[ext_resource type="Resource" path="res://games/crystal/data/encounters/crystal_shard_skirmish.tres" id="3_skirmish"]
