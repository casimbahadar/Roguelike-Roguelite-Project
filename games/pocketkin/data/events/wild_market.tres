[ext_resource type="Script" path="res://core/data/event_choice.gd" id="2_choice"]

[sub_resource type="Resource" id="ChoiceTrade"]
script = ExtResource("2_choice")
label = "Trade for a sealed cache"
outcome_text = "You exchange a fistful of coin for a sealed cedarwood box. Inside, a clutch of curing herbs you can use on the next hard road."
gold_delta = -4
meta_currency_delta = 5
party_hp_delta = 0

[sub_resource type="Resource" id="ChoicePass"]
script = ExtResource("2_choice")
label = "Pass through without trading"
outcome_text = "The vendors close their stalls behind your column without a word. The market was here yesterday. It will not be here tomorrow."
gold_delta = 0
meta_currency_delta = 0
party_hp_delta = 0

[resource]
script = ExtResource("1_def")
id = &"wild_market"
display_name = "A Wild Market"
body = "Half a dozen folding stalls have unfurled themselves on a clearing the road runs through. The vendors don't speak to each other. None of them will be here tomorrow."
choices = [SubResource("ChoiceTrade"), SubResource("ChoicePass")]
act_min = 0
act_max = 99
weight = 9
