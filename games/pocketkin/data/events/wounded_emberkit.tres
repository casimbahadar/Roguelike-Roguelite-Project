[sub_resource type="Resource" id="ChoiceTend"]
script = ExtResource("2_choice")
label = "Tend the kit's wound"
outcome_text = "The kit recovers its breath, lifts a small ember in salute, and bounds away into the brush. A fortnight later a cache-stash turns up at your camp gate."
gold_delta = 0
meta_currency_delta = 5
party_hp_delta = 0

[sub_resource type="Resource" id="ChoiceLeave"]
script = ExtResource("2_choice")
label = "Step around it and march on"
outcome_text = "The kit's eyes follow you out of sight. Your column does not look back."
gold_delta = 0
meta_currency_delta = 0
party_hp_delta = 0

[resource]
script = ExtResource("1_def")
id = &"wounded_emberkit"
display_name = "A Wounded Emberkit"
body = "A young emberkit lies in the road, breathing hard. A poacher's snare has bitten into its hind leg. Its tail-spark guttering low."
choices = [SubResource("ChoiceTend"), SubResource("ChoiceLeave")]
act_min = 0
act_max = 99
weight = 12
