[ext_resource type="Script" path="res://core/data/event_choice.gd" id="2_choice"]

[sub_resource type="Resource" id="ChoiceJoin"]
script = ExtResource("2_choice")
label = "Walk with the migration for a day"
outcome_text = "You match the herd's slow pace under the long sun. Pocketkin riding the column's flanks lift their heads at your wardens — recognition, of a kind."
gold_delta = 0
meta_currency_delta = 6
party_hp_delta = -1

[sub_resource type="Resource" id="ChoiceSkirt"]
script = ExtResource("2_choice")
label = "Skirt the migration and push on"
outcome_text = "Your column threads between the migrating herds. The going is fast and the herds give you no thought at all."
gold_delta = 0
meta_currency_delta = 0
party_hp_delta = 0

[resource]
script = ExtResource("1_def")
id = &"great_migration"
display_name = "The Great Migration"
body = "A long, low river of pocketkin pours across the road — a seasonal migration that wardens are taught to honour. Joining the column on its slow walk is an old custom. So is staying out of its way."
choices = [SubResource("ChoiceJoin"), SubResource("ChoiceSkirt")]
act_min = 0
act_max = 99
weight = 9
