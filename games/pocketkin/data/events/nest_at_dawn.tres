[ext_resource type="Script" path="res://core/data/event_choice.gd" id="2_choice"]

[sub_resource type="Resource" id="ChoiceLinger"]
script = ExtResource("2_choice")
label = "Linger and watch the nest until dawn"
outcome_text = "Your party rests in the long grass and watches the galefinch chicks call to a parent overhead. Something settles in the company that the road had not."
gold_delta = 0
meta_currency_delta = 3
party_hp_delta = 1

[sub_resource type="Resource" id="ChoiceMove"]
script = ExtResource("2_choice")
label = "Move out before the light"
outcome_text = "You break camp under stars, leave no track, and miss the dawn-call entirely."
gold_delta = 0
meta_currency_delta = 0
party_hp_delta = 0

[resource]
script = ExtResource("1_def")
id = &"nest_at_dawn"
display_name = "Nest at Dawn"
body = "Your scout finds a galefinch nest in the cliff-shadow above your camp. Three chicks, almost full-grown, waiting on a parent to come home with the dawn."
choices = [SubResource("ChoiceLinger"), SubResource("ChoiceMove")]
act_min = 0
act_max = 99
weight = 8
