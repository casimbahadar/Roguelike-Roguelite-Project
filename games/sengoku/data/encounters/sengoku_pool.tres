[gd_resource type="Resource" script_class="EncounterPool" load_steps=6 format=3]

[ext_resource type="Script" path="res://core/data/encounter_pool.gd" id="1_pool"]
[ext_resource type="Resource" path="res://games/sengoku/data/encounters/light_battle.tres" id="2_light"]
[ext_resource type="Resource" path="res://games/sengoku/data/encounters/medium_battle.tres" id="3_medium"]
[ext_resource type="Resource" path="res://games/sengoku/data/encounters/elite_skirmish.tres" id="4_elite"]
[ext_resource type="Resource" path="res://games/sengoku/data/encounters/act1_boss.tres" id="5_boss"]

[resource]
script = ExtResource("1_pool")
id = &"sengoku_pool"
battle_encounters = [ExtResource("2_light"), ExtResource("3_medium")]
elite_encounters = [ExtResource("4_elite")]
boss_encounters = [ExtResource("5_boss")]
