[sub_resource type="Resource" id="ChoiceSiftSoil"]
script = ExtResource("2_choice")
label = "Sift the soil"
outcome_text = "Your retainers come up with three coin-purses, an enamel sake-cup, and a mouthful of caltrops. Two of them limp."
