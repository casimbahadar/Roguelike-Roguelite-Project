[gd_resource type="Resource" script_class="EventDef" load_steps=4 format=3]

[ext_resource type="Script" path="res://core/data/event_def.gd" id="1_def"]
[ext_resource type="Script" path="res://core/data/event_choice.gd" id="2_choice"]

[sub_resource type="Resource" id="ChoiceGiveAlms"]
script = ExtResource("2_choice")
label = "Give alms"
outcome_text = "The beggar's eyes go bright. He lifts a thumb-print from his sleeve — a guard-captain's sigil, washed and folded for years. Worth more than the coin you gave."
gold_delta = -3
meta_currency_delta = 5
party_hp_delta = 0

[sub_resource type="Resource" id="ChoiceTakeCoin"]
script = ExtResource("2_choice")
label = "Search his bowl"
outcome_text = "Three coppers and a thin piece of dried fish. A retainer hisses about luck. The beggar curses you under his breath."
gold_delta = 4
meta_currency_delta = -2
party_hp_delta = 0

[sub_resource type="Resource" id="ChoiceWalkPast"]
script = ExtResource("2_choice")
label = "Walk past"
outcome_text = "He does not look up. The road takes you on."
gold_delta = 0
meta_currency_delta = 0
party_hp_delta = 0

[resource]
script = ExtResource("1_def")
id = &"crossroads_beggar"
display_name = "The Crossroads Beggar"
body = "An old man sits at the fork of two roads, his bowl out, his eyes shut. Three roads meet here, but only one of them sees travelers anymore."
choices = [SubResource("ChoiceGiveAlms"), SubResource("ChoiceTakeCoin"), SubResource("ChoiceWalkPast")]
act_min = 0
act_max = 99
weight = 10
