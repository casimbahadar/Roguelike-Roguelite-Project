[ext_resource type="Script" path="res://core/data/event_choice.gd" id="2_choice"]

[sub_resource type="Resource" id="ChoiceShareRations"]
script = ExtResource("2_choice")
label = "Share your rations"
outcome_text = "The farmer presses something into your captain's palm — a bone whistle, his grandfather's. Your column eats lighter the rest of the day."
gold_delta = -2
meta_currency_delta = 3
party_hp_delta = -1

[sub_resource type="Resource" id="ChoiceBuyHisHorse"]
script = ExtResource("2_choice")
label = "Buy his draft horse"
outcome_text = "The animal is half-starved but sound. Your column moves a notch faster, but the farmer's purse is now your gold."
gold_delta = -6
meta_currency_delta = 4
party_hp_delta = 0

[sub_resource type="Resource" id="ChoiceWalkPast2"]
script = ExtResource("2_choice")
label = "Walk past"
outcome_text = "His face does not change. You suspect this is not the first column today."
gold_delta = 0
meta_currency_delta = -1
party_hp_delta = 0

[resource]
script = ExtResource("1_def")
id = &"starving_farmer"
display_name = "A Starving Farmer"
body = "A farmer kneels by the road with the last sack of his harvest open in front of him. His children are not visible. The sack is mostly stones."
choices = [SubResource("ChoiceShareRations"), SubResource("ChoiceBuyHisHorse"), SubResource("ChoiceWalkPast2")]
act_min = 0
act_max = 99
weight = 9
